# Azure AI Document Intelligence
# 例: https://<resource-name>.cognitiveservices.azure.com/
DI_ENDPOINT=
# 認証: auto | key | identity
# auto (デフォルト): DI_KEY があればキー認証、なければ DefaultAzureCredential (マネージド ID / Entra ID)
# key: 常に API キー認証 (DI_KEY 必須)
# identity: 常に DefaultAzureCredential
DI_AUTH_MODE=auto
# DI_AUTH_MODE=key の場合のみ必要。auto/identity の場合は空欄で構いません。
DI_KEY=

# Azure AI Content Understanding
# 例: https://<foundry-resource-name>.cognitiveservices.azure.com/
# project endpoint ではなく、リソースのルート endpoint を指定してください。
CU_ENDPOINT=
# 認証: auto | key | identity
# auto (デフォルト): CU_KEY があればキー認証、なければ DefaultAzureCredential (マネージド ID / Entra ID)
# key: 常に API キー認証 (CU_KEY 必須)
# identity: 常に DefaultAzureCredential
CU_AUTH_MODE=auto
# CU_AUTH_MODE=key の場合のみ必要。auto/identity の場合は空欄で構いません。
CU_KEY=

# Storage backend: "local" (default, local filesystem / SMB mount) or "blob" (Azure Blob Storage)
# blob モードでは DefaultAzureCredential によるマネージド ID 認証を使用し、
# ストレージアカウントキーは不要です。
STORAGE_BACKEND=local

# Azure Blob Storage (STORAGE_BACKEND=blob の場合に必要)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=appstorage

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
