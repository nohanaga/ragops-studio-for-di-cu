# Azure AI Document Intelligence
# e.g. https://<resource-name>.cognitiveservices.azure.com/
DI_ENDPOINT=
# Authentication: auto | key | identity
# auto (default): Uses key auth if DI_KEY is set, otherwise DefaultAzureCredential (Managed Identity / Entra ID)
# key: Always use API key authentication (DI_KEY required)
# identity: Always use DefaultAzureCredential
DI_AUTH_MODE=auto
# Required only when DI_AUTH_MODE=key. Can be left empty for auto/identity.
DI_KEY=

# Azure AI Content Understanding
# e.g. https://<foundry-resource-name>.cognitiveservices.azure.com/
# Specify the root endpoint of the resource, not the project endpoint.
CU_ENDPOINT=
# Authentication: auto | key | identity
# auto (default): Uses key auth if CU_KEY is set, otherwise DefaultAzureCredential (Managed Identity / Entra ID)
# key: Always use API key authentication (CU_KEY required)
# identity: Always use DefaultAzureCredential
CU_AUTH_MODE=auto
# Required only when CU_AUTH_MODE=key. Can be left empty for auto/identity.
CU_KEY=

# Storage backend: "local" (default, local filesystem / SMB mount) or "blob" (Azure Blob Storage)
# In blob mode, Managed Identity authentication via DefaultAzureCredential is used;
# no storage account key is required.
STORAGE_BACKEND=local

# Azure Blob Storage (required when STORAGE_BACKEND=blob)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=appstorage

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
